# ── Telegram Bot Configuration ──

# Bot Tokens obtained from @BotFather
MAIN_BOT_TOKEN=your_main_bot_token_here
LOGIN_BOT_TOKEN=your_login_bot_token_here

# Bot Usernames (without @)
MAIN_BOT_USERNAME=YourMainBot
LOGIN_BOT_USERNAME=spinifyLoginbot

# ── Owner / Admin ───────────────────
# Your numeric Telegram User ID
OWNER_ID=your_telegram_user_id

# ── Database & Cache ────────────────
# MongoDB Atlas or local connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/spinify?retryWrites=true&w=majority
MONGODB_DB_NAME=spinify

# Redis (Required for distributed scheduler + worker communication)
REDIS_URL=redis://redis:6379

# ── Community & Support ─────────────
CHANNEL_USERNAME=PHilobots
SUPPORT_HANDLE=@spinify
SUPPORT_URL=https://t.me/spinify
PAYMENT_UPI_ID=rain@slc

# ── Premium Scheduling Rules ────────
# Minimum interval users can set (in minutes)
MIN_INTERVAL_MINUTES=15
DEFAULT_INTERVAL_MINUTES=15

# Premium Gaps (optimized for performance)
# Time to wait between forwarding to different groups (seconds)
GROUP_GAP_SECONDS=45

# Time to wait between forwarding different messages (seconds)
MESSAGE_GAP_SECONDS=210

# Maximum groups allowed per user
MAX_GROUPS_PER_USER=100

# ── Advanced Worker Settings ────────
WORKER_CONCURRENCY=10
SESSION_POOL_MAX_SIZE=200
SESSION_POOL_IDLE_TTL=1800  # 30 minutes in seconds

# ── Scheduler Performance ───────────
# How often to check for due jobs (seconds)
SCHEDULER_POLL_INTERVAL=1.5
DEAD_WORKER_THRESHOLD_SECONDS=120

# ── Rate Limit Protection ───────────
# Random jitter delay between single messages
SEND_DELAY_MIN=10
SEND_DELAY_MAX=20

# ── Night Mode (IST) ────────────────
# Global system-wide pause hours
NIGHT_MODE_START_HOUR=0
NIGHT_MODE_END_HOUR=6
TIMEZONE=Asia/Kolkata
